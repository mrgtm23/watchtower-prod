# Database
POSTGRES_USER=watchtower
POSTGRES_PASSWORD=watchpass
POSTGRES_DB=watchtower
DATABASE_URL=postgresql+psycopg2://watchtower:watchpass@db:5432/watchtower

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=models

# MLflow
MLFLOW_URI=http://mlflow:5000

# MLflow/S3 Configuration
MLFLOW_S3_ENDPOINT_URL=http://minio:9000
MLFLOW_S3_IGNORE_TLS=true
# Use the same credentials as MLflow service
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# JWT
SECRET_KEY=change-this-to-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Grafana creds
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
